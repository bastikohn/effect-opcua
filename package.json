{
  "name": "effect-opcua",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "vp run --filter='@effect-opcua/*' build",
    "check": "pnpm lint && pnpm format && pnpm typecheck && pnpm test:types && pnpm test",
    "check:ci": "pnpm check && pnpm build && pnpm smoke:packages",
    "check:release": "pnpm check:ci && node scripts/publish-public-packages.mjs --dry-run",
    "changeset": "changeset",
    "changeset:publish": "node scripts/publish-public-packages.mjs",
    "changeset:status": "changeset status --since=origin/main",
    "changeset:version": "changeset version && pnpm install --lockfile-only",
    "dev": "vp run --filter='@effect-opcua/*' --parallel dev",
    "dev:server": "vp run --filter @effect-opcua/demo-server start",
    "dev:tui": "vp run --filter @effect-opcua/tui start",
    "format": "vp fmt --check",
    "lint": "vp lint --report-unused-disable-directives",
    "smoke:packages": "node scripts/package-smoke.mjs",
    "test": "pnpm test:unit",
    "test:coverage": "vp run --filter='@effect-opcua/*' --concurrency-limit 1 test -- --coverage",
    "test:integration": "vp run --filter @effect-opcua/client test",
    "test:types": "tstyche",
    "test:unit": "vp run --filter='@effect-opcua/*' --concurrency-limit 1 test",
    "typecheck": "vp run --filter='@effect-opcua/*' typecheck",
    "fix": "vp fmt && vp lint --fix",
    "clean": "vp run --filter='@effect-opcua/*' clean && rm -rf node_modules"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@effect/language-service": "^0.87.0",
    "@oxlint/plugins": "^1.74.0",
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.12",
    "tstyche": "^7.2.2",
    "typescript": "^7.0.2",
    "unrun": "^0.3.1",
    "vite-plus": "^0.2.5",
    "vitest": "^4.1.10"
  }
}
