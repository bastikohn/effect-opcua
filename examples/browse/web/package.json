{
  "name": "@effect-opcua/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/shared/index.d.mts",
      "default": "./dist/shared/index.mjs"
    },
    "./server": {
      "types": "./dist/server/index.d.mts",
      "default": "./dist/server/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "effect-opcua-web": "./dist/server/main.mjs"
  },
  "scripts": {
    "build": "pnpm build:server && pnpm build:client",
    "build:client": "vite build",
    "build:server": "pnpm --filter @effect-opcua/client build && tsdown --config-loader unrun",
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "pnpm build:server && pnpm start:rpc",
    "start": "pnpm start:rpc",
    "start:rpc": "node dist/server/main.mjs",
    "typecheck": "svelte-check --tsconfig tsconfig.json && tsc --noEmit --project tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage node_modules .svelte-kit"
  },
  "dependencies": {
    "@effect-opcua/client": "workspace:*",
    "@effect/platform-browser": "4.0.0-beta.66",
    "@effect/platform-node": "4.0.0-beta.66",
    "@tailwindcss/vite": "^4.0.0",
    "effect": "4.0.0-beta.66",
    "lucide-svelte": "^0.468.0",
    "svelte": "^5.56.0",
    "tailwindcss": "^4.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "svelte-check": "^4.0.0"
  }
}
