{
  "name": "@effect-opcua/client",
  "version": "0.1.0-alpha.0",
  "description": "Effect-native OPC-UA client wrapper for node-opcua",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "package.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastikohn/effect-opcua.git",
    "directory": "packages/client"
  },
  "bugs": {
    "url": "https://github.com/bastikohn/effect-opcua/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./node-opcua": {
      "types": "./dist/node-opcua.d.mts",
      "default": "./dist/node-opcua.mjs"
    },
    "./Opcua": {
      "types": "./dist/Opcua.d.mts",
      "default": "./dist/Opcua.mjs"
    },
    "./OpcuaClient": {
      "types": "./dist/OpcuaClient.d.mts",
      "default": "./dist/OpcuaClient.mjs"
    },
    "./OpcuaError": {
      "types": "./dist/OpcuaError.d.mts",
      "default": "./dist/OpcuaError.mjs"
    },
    "./package.json": "./package.json",
    "./internal/*": null
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "dev": "tsdown --watch --config-loader unrun",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage node_modules"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.66"
  },
  "dependencies": {
    "node-opcua": "^2.170.0"
  },
  "devDependencies": {}
}
