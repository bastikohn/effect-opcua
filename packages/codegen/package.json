{
  "name": "@effect-opcua/codegen",
  "version": "0.1.0-alpha.2",
  "description": "Effect OPC-UA client code generator",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "package.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastikohn/effect-opcua.git",
    "directory": "packages/codegen"
  },
  "bugs": {
    "url": "https://github.com/bastikohn/effect-opcua/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json",
    "./internal/*": null
  },
  "bin": {
    "effect-opcua-codegen": "dist/cli.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "dev": "tsdown --watch --config-loader unrun",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage node_modules"
  },
  "peerDependencies": {
    "effect": "catalog:"
  },
  "dependencies": {
    "@effect-opcua/client": "workspace:*",
    "@effect/platform-node": "catalog:",
    "unrun": "^0.3.0"
  },
  "devDependencies": {}
}
