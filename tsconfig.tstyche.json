{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [],
    "verbatimModuleSyntax": false,
    "paths": {
      "@effect-opcua/codegen": ["packages/codegen/src/index.ts"],
      "@effect-opcua/client": ["packages/client/src/index.ts"],
      "@effect-opcua/client/node-opcua": ["packages/client/src/node-opcua.ts"],
      "@effect-opcua/client/Opcua": ["packages/client/src/Opcua.ts"],
      "@effect-opcua/client/OpcuaClient": [
        "packages/client/src/OpcuaClient.ts"
      ],
      "@effect-opcua/client/OpcuaError": ["packages/client/src/OpcuaError.ts"]
    }
  },
  "include": [
    "packages/codegen/src",
    "packages/codegen/test/**/*.tst.ts",
    "packages/client/src",
    "packages/client/test/**/*.tst.ts",
    "examples/demo-machine/client/src",
    "examples/demo-machine/client/test/**/*.tst.ts"
  ]
}
