{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "plugins": [],
    "verbatimModuleSyntax": false,
    "paths": {
      "@effect-opcua/client": ["packages/client/src/index.ts"],
      "@effect-opcua/client/node-opcua": ["packages/client/src/node-opcua.ts"],
      "@effect-opcua/client/*": ["packages/client/src/*.ts"]
    }
  },
  "include": [
    "packages/client/src",
    "packages/client/test/**/*.tst.ts",
    "examples/demo-client/src",
    "examples/demo-client/test/**/*.tst.ts"
  ]
}
